{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "ink", "color": "#17201c", "name": "Ink" },
        { "slug": "sage", "color": "#6c7f73", "name": "Sage" },
        { "slug": "paper", "color": "#f7f2ea", "name": "Paper" },
        { "slug": "linen", "color": "#e9dfcf", "name": "Linen" },
        { "slug": "bronze", "color": "#8f6449", "name": "Bronze" }
      ]
    },
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1360px"
    },
    "spacing": {
      "units": ["px", "rem", "vw", "%"],
      "padding": true,
      "margin": true
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fontFamilies": [
        {
          "fontFamily": "Georgia, 'Times New Roman', Times, serif",
          "name": "Editorial Serif",
          "slug": "editorial-serif"
        },
        {
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Editorial Sans",
          "slug": "editorial-sans"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#f7f2ea",
      "text": "#17201c"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--editorial-serif)"
    }
  }
}

